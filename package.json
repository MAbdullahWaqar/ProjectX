{
  "name": "realdoor",
  "version": "1.0.0",
  "description": "RealDoor — renter-side application-readiness copilot (RealPage × Hack-Nation Challenge 03).",
  "private": true,
  "scripts": {
    "start": "node -e \"const p=require('http').createServer((q,s)=>{const fs=require('fs'),path=require('path');let f=q.url==='/'?'/index.html':q.url.split('?')[0];const t={'.html':'text/html','.js':'text/javascript','.css':'text/css','.json':'application/json','.txt':'text/plain'};try{const b=fs.readFileSync('.'+f);s.writeHead(200,{'content-type':t[path.extname(f)]||'application/octet-stream'});s.end(b);}catch(e){s.writeHead(404);s.end('not found');}}).listen(5173,()=>console.log('RealDoor running at http://localhost:5173'));\"",
    "test": "node test/engine.test.js",
    "test:ui": "node test/ui.smoke.js"
  },
  "devDependencies": {
    "jsdom": "^24.0.0"
  }
}
